export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"

SOURCES_CODES="{{ get . "sources_codes" | default ""  }}"
export SOURCES_CODES="${SOURCES_CODES:-${HOME}/.sources_codes}"
PROGRAMS_DIR="{{ get . "programs_dir" | default ""  }}"
export PROGRAMS_DIR="${PROGRAMS_DIR:-${HOME}/.local}"

export ZSH="${PROGRAMS_DIR}/oh-my-zsh"

export LANG="{{ get . "lang" | default "C.UTF-8" }}"
export LC_ALL="{{ get . "lc_all" | default "C.UTF-8" }}"

{{ if .utilities.zsh.enable }}
#zsh
ZSH_CACHE_DIR="{{ get .utilities.zsh "cache" | default "" }}"
ZSH_CACHE_DIR=${ZSH_CACHE_DIR:-${XDG_CACHE_HOME}/zsh}
if [[ ! -d "${ZSH_CACHE_DIR}" ]]; then
    mkdir -p "${ZSH_CACHE_DIR}"
fi
ZSH_COMPDUMP="{{ get .utilities.zsh "compdump" | default "" }}"
export ZSH_COMPDUMP="${ZSH_COMPDUMP:-${ZSH_CACHE_DIRE}/.zcompdump}"
ZSH_HISTFILE="{{ get .utilities.zsh "histfile" | default "" }}"
export HISTFILE="${ZSH_HISTFILE:-${ZSH_CACHE_DIR}/history}"
{{ end }}

{{ if .utilities.tmux }}
#tmux
alias tmux="TERM=screen-256color-bce tmux"
{{ end }}

{{ if .utilities.neovim.enable }}

LOCAL_PROGRAMS_DIR="{{ get . "programs_dir" | default ""  }}"
LOCAL_PROGRAMS_DIR=${LOCAL_PROGRAMS_DIR:-${HOME}/.local}
NVIM_PROGRAM_DIR="{{ get .utilities.neovim "program_dir" | default ""  }}"
NVIM_PROGRAM_DIR="${NVIM_PROGRAM_DIR:-${LOCAL_PROGRAMS_DIR}/neovim}"

export PATH="${NVIM_PROGRAM_DIR}/bin:${PATH}" 
#chezmoi
export EDITOR="${NVIM_PROGRAM_DIR}/bin/nvim"
{{ end }}

{{- if and .python.enable .python.pyenv.enable }}
PYENV_ROOT={{ .python.pyenv.root }}
export PYENV_ROOT=${PYENV_ROOT:-${HOME}/.local/pyenv}
export PATH="${PYENV_ROOT}/bin:${PATH}"
eval "$(pyenv init -)"
{{- end }}
